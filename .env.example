DATABASE_URL=
OPENAI_API_KEY=
RESEND_API_KEY=

# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=
NEXTAUTH_URL=

AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=

# Geocoding API and Places API (New)
GOOGLE_PLACES_API_KEY=
# Maps JavaScript API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# Map ID for Advanced Markers (Cloud console -> Maps Platform -> Map management).
# Optional: Google's DEMO_MAP_ID is used when unset.
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=

# Cloudflare Browser Rendering — used by the crawler to fetch site markdown
# Account ID: Cloudflare dashboard -> any domain -> Overview (right sidebar), or the URL after /accounts/
# API Token: My Profile -> API Tokens -> Create Token, with the "Browser Rendering - Edit" permission
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Hard monthly cap on billable Google Places calls. Keep below Google's free tier
# (5,000 Pro events/mo) so the public add-a-school flow can never run up a bill.
PLACES_MONTHLY_CAP=4500

# Cloudflare Turnstile — gates the public add-a-school flow against bots.
# Create a widget at Cloudflare dashboard -> Turnstile.
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Shared secret for the scheduled photo-refresh cron route. Vercel Cron sends it
# as "Authorization: Bearer <CRON_SECRET>".
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=


